---
import '../styles/global.css';
import logo from '../assets/img/GE-Blue-Vector.png';

interface Props {
  title?: string;
  activePage?: 'home' | 'about' | 'ai-use';
}

const { title = 'Good Enough — Reclaiming Good Enough for Government', activePage = 'home' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Consulting for city governments on data, AI, design, and service delivery." />
  </head>
  <body>

    <header>
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <img src={logo.src} alt="Good Enough" />
        </a>
        <nav>
          <a href="/" class:list={[{ active: activePage === 'home' }]}>Home</a>
          <a href="/about" class:list={[{ active: activePage === 'about' }]}>About</a>
          <a href="/ai-use" class:list={[{ active: activePage === 'ai-use' }]}>AI @ GE</a>
          <a href="https://goodenough4gov.substack.com" target="_blank" rel="noopener">Writing</a>
          <a href="mailto:justin@goodenough4gov.com">Contact</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer>
      <div class="footer-inner">
        <div class="footer-name">Good Enough</div>
        <div class="footer-contact">
          Baltimore, MD · <a href="mailto:justin@goodenough4gov.com">justin@goodenough4gov.com</a>
        </div>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ── Nav ── */
  header {
    border-bottom: 1px solid rgba(23, 23, 23, 0.10);
  }
  .nav-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo img {
    height: 2rem;
    display: block;
  }
  nav {
    display: flex;
    gap: 2rem;
  }
  nav a {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--n900);
    text-decoration: none;
    transition: color 0.2s;
  }
  nav a:hover {
    color: var(--cobalt);
  }
  nav a.active {
    color: var(--cobalt);
    border-bottom: 2px solid var(--cobalt);
    padding-bottom: 2px;
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid rgba(23, 23, 23, 0.10);
  }
  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-size: 0.875rem;
  }
  .footer-name {
    font-family: 'Didot', 'GFS Didot', Georgia, serif;
    font-size: 1.25rem;
  }
  .footer-contact { color: var(--n600); }
  .footer-contact a { color: inherit; text-decoration: none; }
  .footer-contact a:hover { color: var(--cobalt); }

  @media (max-width: 640px) {
    nav { gap: 1rem; }
  }
</style>
