---
import Layout from '../layouts/Layout.astro';
import MapboxCityMap from '../components/MapboxCityMap.astro';
import coralLine from '../assets/img/coral-line.png';
import govexLogo  from '../assets/img/logo-govex.png';
import bcpiLogo   from '../assets/img/logo-bcpi.png';
import everytownLogo from '../assets/img/logo-everytown.svg';
import jhuLogo    from '../assets/img/logo-jhu.png';
---

<Layout activePage="home">

  <!-- ── HERO ── -->
  <section class="hero">
    <p class="hero-eyebrow">Public sector capacity from someone who's been there</p>
    <h1>
      Reclaiming
      <span class="underline-wrap">
        good enough
        <img src={coralLine.src} alt="" aria-hidden="true" class="coral-line" />
      </span>
      for government.
    </h1>
    <p class="hero-body">
      Residents deserve a government that just works. Good Enough is a trusted partner to cities — helping public servants do meaningful work with what they've got.
    </p>
    <a href="#services" class="btn-primary">
      See what we do <span aria-hidden="true">→</span>
    </a>
  </section>

  <!-- ── SERVICES ── -->
  <section class="services" id="services">
    <div class="services-inner">
      <div class="services-header">
        <h2>Services</h2>
      </div>
      <div class="services-cols">

        <div class="service-col">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="#2708A0" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 8 C14 5 26 5 26 8 L28 14 C30 16 30 24 28 26 L26 32 C26 35 14 35 14 32 L12 26 C10 24 10 16 12 14 Z"/>
              <line x1="17" y1="16" x2="17" y2="24"/>
              <line x1="20" y1="14" x2="20" y2="26"/>
              <line x1="23" y1="16" x2="23" y2="24"/>
            </svg>
          </div>
          <div class="service-num">01</div>
          <h3>Artificial Intelligence</h3>
          <p>Helping cities adopt, govern, and get real value from AI — responsibly and at the pace that works for them.</p>
        </div>

        <div class="service-col">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="#2708A0" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <ellipse cx="20" cy="10" rx="13" ry="4"/>
              <path d="M7 10 L7 20 C7 22.2 13 24 20 24 C27 24 33 22.2 33 20 L33 10"/>
              <path d="M7 20 L7 30 C7 32.2 13 34 20 34 C27 34 33 32.2 33 30 L33 20"/>
            </svg>
          </div>
          <div class="service-num">02</div>
          <h3>Data</h3>
          <p>Building the data infrastructure, literacy, and culture that lets local governments use evidence to drive decisions.</p>
        </div>

        <div class="service-col">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="#2708A0" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="12" y="5" width="16" height="30" rx="2"/>
              <line x1="12" y1="9" x2="28" y2="9"/>
              <line x1="12" y1="31" x2="28" y2="31"/>
              <circle cx="20" cy="33" r="0.75" fill="#2708A0"/>
            </svg>
          </div>
          <div class="service-num">03</div>
          <h3>Digital Services</h3>
          <p>Modern digital products and platforms that make government easier to interact with and services easier to deliver.</p>
        </div>

        <div class="service-col">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="#2708A0" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6 C13 6 8 11 8 17 C8 21.5 10.5 25.3 14 27.2 L14 31 L26 31 L26 27.2 C29.5 25.3 32 21.5 32 17 C32 11 27 6 20 6Z"/>
              <line x1="16" y1="31" x2="16" y2="34"/>
              <line x1="24" y1="31" x2="24" y2="34"/>
              <line x1="16" y1="34" x2="24" y2="34"/>
              <line x1="20" y1="11" x2="20" y2="16"/>
              <line x1="17.5" y1="13.5" x2="22.5" y2="13.5"/>
            </svg>
          </div>
          <div class="service-num">04</div>
          <h3>Innovation &amp; Design</h3>
          <p>Applying human-centered design and structured innovation methods to improve how cities work from the inside out.</p>
        </div>

        <div class="service-col">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" stroke="#2708A0" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <!-- Front wheel -->
              <circle cx="11" cy="28" r="4"/>
              <circle cx="11" cy="28" r="1.8"/>
              <!-- Rear wheel -->
              <circle cx="31" cy="28" r="4"/>
              <circle cx="31" cy="28" r="1.8"/>
              <!-- Front wing -->
              <polygon points="4,23 8,21 8,25" fill="none"/>
              <!-- Car body -->
              <path d="M 7 28 L 7 24 L 9 21 L 13 20 L 17 19 L 21 19 L 24 17 L 29 17 L 32 20 L 35 22 L 35 28"/>
              <path d="M 15 28 L 27 28"/>
              <!-- Number plate area -->
              <rect x="18" y="19" width="5" height="4" rx="0.5"/>
              <!-- Rear wing -->
              <line x1="32" y1="13" x2="37" y2="13"/>
              <line x1="33.5" y1="13" x2="33.5" y2="17"/>
            </svg>
          </div>
          <div class="service-num">05</div>
          <h3>City Operations &amp; Performance</h3>
          <p>Strengthening the management systems, metrics, and cross-agency coordination that make city hall run better.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CITIES MAP ── -->
  <section class="cities-map">
    <div class="cities-inner">
      <div class="cities-header">
        <h2>Our Reach</h2>
        <p>Good Enough is proud to have supported governments and institutions across the U.S. and Canada.</p>
      </div>
      
      <MapboxCityMap />
    </div>
  </section>

  <!-- ── FEATURED PARTNERS ── -->
  <section class="partners">
    <div class="partners-inner">
      <div class="partners-header">
        <h2>Featured Partners</h2>
        <p>Good Enough partners with these institutions to bring our expertise to cities and governments.</p>

      </div>
      <div class="partners-grid">
        <div class="partner-stack">
          <div class="partner-logo logo-govex">
            <img src={govexLogo.src} alt="GovEx — Bloomberg Center for Government Excellence at Johns Hopkins" />
          </div>
          <div class="partner-logo logo-bcpi">
            <img src={bcpiLogo.src} alt="Bloomberg Center for Public Innovation at Johns Hopkins" />
          </div>
        </div>
        <div class="partner-stack">
          <div class="partner-logo logo-everytown">
            <img src={everytownLogo.src} alt="Everytown for Gun Safety" />
          </div>
          <div class="partner-logo logo-jhu">
            <img src={jhuLogo.src} alt="Johns Hopkins University" />
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    max-width: 72rem;
    margin: 0 auto;
    padding: 8rem 1.5rem 8rem;
  }
  .hero-eyebrow {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--cobalt);
    margin-bottom: 2rem;
  }
  h1 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 3rem;
    max-width: 62rem;
  }
  .underline-wrap {
    position: relative;
    display: inline-block;
  }
  .coral-line {
    position: absolute;
    left: 0;
    bottom: -1.25rem;
    width: 100%;
    height: auto;
    display: block;
  }
  .hero-body {
    font-size: 1.25rem;
    line-height: 1.7;
    max-width: 38rem;
    color: var(--n700);
    margin-bottom: 4rem;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--cobalt);
    color: var(--bg);
    padding: 1rem 2rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    font-family: "Barlow Semi Condensed", "Helvetica Neue", Arial, sans-serif;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--n900); }

  /* ── Services ── */
  .services {
    border-top: 1px solid rgba(23, 23, 23, 0.10);
    background: var(--bg);
  }
  .services-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 6rem 1.5rem;
  }
  .services-header {
    margin-bottom: 4rem;
  }
  .services-header h2 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .services-header p {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--n700);
    max-width: 50rem;
    margin: 0;
  }
  .services-cols {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: rgba(23, 23, 23, 0.10);
  }
  .service-col {
    background: var(--bg);
    padding: 2rem 1.5rem 2.5rem;
    display: flex;
    flex-direction: column;
  }
  .service-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 1.5rem;
    flex-shrink: 0;
  }
  .service-icon svg { width: 100%; height: 100%; }
  .service-num {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--cobalt);
    margin-bottom: 0.6rem;
  }
  .service-col h3 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 1.15rem;
    line-height: 1.25;
    margin-bottom: 0.85rem;
  }
  .service-col p {
    color: var(--n700);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* ── Cities Map ── */
  .cities-map {
    border-top: 1px solid rgba(23, 23, 23, 0.10);
    background: var(--bg);
  }
  .cities-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 6rem 1.5rem;
  }
  .cities-header {
    margin-bottom: 3rem;
  }
  .cities-header h2 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .cities-header p {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--n700);
    max-width: 50rem;
    margin: 0;
  }

  /* ── Partners ── */
  .partners {
    border-top: 1px solid rgba(23, 23, 23, 0.10);
    border-bottom: 1px solid rgba(23, 23, 23, 0.10);
  }
  .partners-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3.5rem .5rem;
  }
  .partners-header {
    margin-bottom: 2.5rem;
  }
  .partners-header h2 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .partners-header p {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--n700);
    max-width: 50rem;
    margin: 0;
  }
  .partners-grid {
    display: grid;
    grid-template-columns: auto auto;
    gap: 2.5rem 5.5rem;
    align-items: center;
    justify-content: center;
  }
  .partner-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .partner-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: auto;
    height: 200px;
    opacity: 0.60;
    transition: opacity 0.25s;
  }
  .partner-logo:hover { opacity: 1; }
  .partner-logo img {
    height: 60px;
    width: 100%;
    object-fit: contain;
    display: block;
  }
  /* Optical balancing: the compact Everytown mark and the JHU shield read
     larger than the long GovEx/BCPI lockups at equal height, so scale them down. */
  .logo-everytown img { height: 100px; }
  .logo-jhu img { height: 132px; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .services-cols { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .services-cols { grid-template-columns: repeat(2, 1fr); }
    .partners-grid { grid-template-columns: 1fr; gap: 1rem; justify-content: center; }
    .partner-stack { gap: 0.5rem; }
  }
</style>
