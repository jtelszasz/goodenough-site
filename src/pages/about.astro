---
import Layout from '../layouts/Layout.astro';
import headshot from '../assets/img/Justin Elszasz Headshot 2026 02.JPG';
---

<Layout activePage="about">

  <section class="about">
    <div class="about-inner">

      <div class="content">
        <p class="about-label">About</p>
        <h1>Building capacity for cities that need it most</h1>

        <div class="bio">
          <p>
            [Why you founded Good Enough — your motivation, the gap you identified in how cities
            access technical capacity, and your vision for what good enough means in the public sector.]
          </p>

          <p>
            [Your background and experience — the roles, organizations, and work that positioned you
            to build Good Enough. Include relevant expertise in data, AI, digital services, city operations,
            or innovation that informs your approach.]
          </p>

          <p>
            [Additional context about your approach or philosophy, if needed.]
          </p>
        </div>
      </div>

      <div class="image">
        <img src={headshot.src} alt="Justin Elszasz" />
      </div>

    </div>
  </section>

</Layout>

<style>
  /* ── About Section ── */
  .about {
    border-bottom: 1px solid rgba(23, 23, 23, 0.10);
  }

  .about-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 6rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: start;
  }

  /* ── Content ── */
  .content {
    max-width: 48rem;
  }

  .about-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--cobalt);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-family: 'Didot', 'GFS Didot', Georgia, serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    max-width: 52rem;
  }

  .bio {
    color: var(--n700);
    font-size: 1.125rem;
    line-height: 1.7;
  }

  .bio p {
    margin-bottom: 1.5rem;
  }

  .bio p:last-child {
    margin-bottom: 0;
  }

  /* ── Image ── */
  .image img {
    display: block;
    width: 220px;
    height: 220px;
    max-width: 220px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 4rem 1.5rem;
    }

    .image {
      order: -1;
      display: flex;
      justify-content: center;
    }

    h1 {
      font-size: clamp(1.75rem, 5vw, 2.5rem);
    }
  }
</style>
